# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# ===== 이카운트 ERP (서버 전용) =====
# 전표 발행(쓰기) — MOCK: 실제 이카운트에 전표를 찍지 않음 (기본값) / REAL: 실제 전표 발행
ECOUNT_MODE=MOCK
ECOUNT_SYNC_ENABLED=false
# 품목·재고 조회(읽기 전용) — true면 전표 모드와 무관하게 실제 이카운트에서 조회
ECOUNT_READ_ENABLED=false
# 주의: 테스트 서버와 실서버는 회사코드가 다릅니다 (docs/ECOUNT_INTEGRATION.md 참고)
#  테스트: ECOUNT_API_BASE_URL=https://sboapi.ecount.com + 테스트 회사코드 + 테스트 인증키
#  실서버: ECOUNT_API_BASE_URL=https://oapi.ecount.com  + 실서버 회사코드 + 실서버 인증키
ECOUNT_COMPANY_CODE=
ECOUNT_API_USER_ID=
ECOUNT_API_KEY=
ECOUNT_API_BASE_URL=https://oapi.ecount.com
ECOUNT_DEFAULT_WAREHOUSE_CODE=
ECOUNT_ORDER_USER_FIELD=

# ===== 크론 (전송 큐/재고 동기화 주기 실행) =====
CRON_SECRET=
